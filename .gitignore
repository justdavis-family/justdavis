*~

# Mise
.mise.lock

# Git worktrees
.worktrees/

# Language-specific patterns added per sub-project

# Environment files (contain credentials — never commit); matched at all repo
# depths so sub-projects can each maintain their own .env without extra entries.
**/.env

# Collector config (personal repo list — define repos in the GH Actions workflow instead;
# see github-analytics/README.md for setup instructions).
**/config.yaml

# Smoke test config (personal repo list — gitignored; see config.smoke.sample.yaml).
**/config.smoke.yaml

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
